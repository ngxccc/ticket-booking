{
  "name": "ticket-booking",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "description": "",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "doppler run -- nest start --watch --exec bun",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"eslint.config.ts\" \"drizzle.config.ts\"",
    "lint": "eslint . --fix --cache --cache-location .eslintcache",
    "start": "doppler run -- bun dist/main.js",
    "start:debug": "doppler run -- nest start --debug --watch",
    "start:prod": "doppler run -- bun dist/main.js",
    "test": "bun test src/",
    "test:cov": "bun test src/ --coverage",
    "test:e2e": "doppler run -- env NODE_ENV=test bun test test/ --max-concurrency=1",
    "test:watch": "bun test src/ --watch",
    "db:baseline": "doppler run -- bun scripts/baseline.ts",
    "db:generate": "doppler run -- drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "doppler run -- drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "doppler run -- drizzle-kit push --config drizzle.config.ts",
    "db:studio": "doppler run -- drizzle-kit studio --config drizzle.config.ts",
    "i18n:generate": "nestjs-i18n -p ./src/i18n/ -o ./src/generated/i18n.generated.ts",
    "check-types": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/throttler": "^6.5.0",
    "@scalar/nestjs-api-reference": "^1.2.11",
    "@t3-oss/env-core": "^0.13.11",
    "bullmq": "^5.81.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^1.0.0-rc.4",
    "fast-deep-equal": "^3.1.3",
    "ioredis": "^5.11.1",
    "nestjs-i18n": "^10.8.5",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.18.0",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.6",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/bun": "^1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.1",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^1.0.0-rc.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.2.0",
    "prettier": "^3.9.6",
    "supertest": "^7.2.2",
    "typescript": "^6",
    "typescript-eslint": "^8.65.0"
  },
  "resolutions": {
    "multer": "^2.2.0",
    "lodash": "^4.18.1",
    "qs": "^6.15.3"
  }
}
