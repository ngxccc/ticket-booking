              "name": "Register",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "if (pm.iterationData.get(\"generateEmail\") === true || pm.iterationData.get(\"generateEmail\") === undefined) {",
                      "    pm.environment.set(\"email\", \"test-\" + Date.now() + \"@example.com\");",
                      "} else if (pm.iterationData.get(\"emailOverride\")) {",
                      "    pm.environment.set(\"email\", pm.iterationData.get(\"emailOverride\"));",
                      "}"
                    ],
                    "type": "text/javascript",
                    "packages": {}
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var expectedStatus = pm.iterationData.get(\"expectedStatus\") || 201;",
                      "var caseName = pm.iterationData.get(\"caseName\") || \"Register: Success (Happy Path)\";",
                      "",
                      "pm.test(caseName + \" - Status code is \" + expectedStatus, function () {",
                      "    pm.response.to.have.status(expectedStatus);",
                      "});",
                      "",
                      "if (expectedStatus === 201) {",
                      "    pm.test(caseName + \" - Response success is true\", function () {",
                      "        var jsonData = pm.response.json();",
                      "        pm.expect(jsonData.success).to.be.true;",
                      "    });",
                      "} else if (expectedStatus === 409) {",
                      "    pm.test(caseName + \" - Response contains email conflict message\", function () {",
                      "        var jsonData = pm.response.json();",
                      "        pm.expect(jsonData.message).to.be.oneOf([\"auth.EMAIL_ALREADY_EXISTS\", \"Email đã tồn tại\"]);",
                      "    });",
                      "} else if (expectedStatus === 400) {",
                      "    pm.test(caseName + \" - Response has validation error\", function () {",
                      "        var responseText = pm.response.text();",
                      "        var expectedError = pm.iterationData.get(\"validationError\") || \"validation\";",
                      "        var hasError = responseText.includes(expectedError) || responseText.toLowerCase().includes(\"không\");",
                      "        pm.expect(hasError).to.be.true;",
                      "    });",
                      "}"
                    ],
                    "type": "text/javascript",
                    "packages": {}
                  }
                }
              ],
              "protocolProfileBehavior": {
                "strictSSL": false,
                "followRedirects": true
              },
              "request": {
                "method": "POST",
                "header": [
